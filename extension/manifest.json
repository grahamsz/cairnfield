{
  "manifest_version": 3,
  "name": "Cairnfield Clipper",
  "description": "Clip pages, selections, and images into Cairnfield.",
  "version": "0.1.0",
  "permissions": ["activeTab", "contextMenus", "debugger", "notifications", "scripting", "storage"],
  "optional_host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["setup-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "single-file/*.js",
        "single-file/core/*.js",
        "single-file/core/lib/*.js",
        "single-file/modules/*.js",
        "single-file/processors/*.js",
        "single-file/processors/compression/*.js",
        "single-file/processors/frame-tree/content/*.js",
        "single-file/processors/hooks/content/*.js",
        "single-file/processors/lazy/content/*.js",
        "single-file/vendor/*.js",
        "single-file/vendor/zip/*.js"
      ],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Clip to Cairnfield",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html"
}
